{
  "productName": "bms-dashtray",
  "version": "0.1.1",
  "identifier": "com.fohte.bms-dashtray",
  "build": {
    "beforeBuildCommand": {
      "script": "pnpm run build",
      "cwd": "../frontend"
    },
    "beforeDevCommand": {
      "script": "pnpm run dev",
      "cwd": "../frontend"
    },
    "devUrl": "http://localhost:1420",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    },
    "windows": [
      {
        "title": "bms-dashtray",
        "width": 380,
        "height": 700,
        "resizable": true,
        "transparent": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
